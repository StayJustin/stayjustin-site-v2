  <style>
    :root {
      --navy: #123b64;
      --blue: #1f74b7;
      --sky: #dff1fb;
      --gold: #f0b544;
      --orange: #e38b2f;
      --green: #2f8f69;
      --green-dark: #217457;
      --text: #17212b;
      --muted: #5d6b78;
      --card: #ffffff;
      --bg: #f5f8fb;
      --border: #d9e3ec;
      --shadow: 0 10px 30px rgba(18, 59, 100, 0.10);
      --radius: 18px;
      --radius-sm: 12px;
      --max: 1180px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: Inter, Arial, Helvetica, sans-serif;
      color: var(--text);
      background: linear-gradient(180deg, #eef6fb 0%, #f7fafc 220px, var(--bg) 100%);
      line-height: 1.5;
    }

    img {
      display: block;
      width: 100%;
      height: auto;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .container {
      width: min(var(--max), calc(100% - 32px));
      margin: 0 auto;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 1000;
      backdrop-filter: blur(10px);
      background: rgba(10, 28, 48, 0.88);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      min-height: 76px;
    }

    .brand {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .brand-title {
      color: #fff;
      font-size: 1.8rem;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .brand-sub {
      color: rgba(255,255,255,0.8);
      font-size: 0.95rem;
      font-weight: 500;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .nav-links a {
      color: rgba(255,255,255,0.92);
      font-weight: 700;
      padding: 12px 14px;
      border-radius: 999px;
      font-size: 0.95rem;
    }

    .nav-links a:hover {
      background: rgba(255,255,255,0.08);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 48px;
      padding: 12px 20px;
      border-radius: 999px;
      font-weight: 800;
      transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
      box-shadow: var(--shadow);
    }

    .btn:hover {
      transform: translateY(-1px);
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--blue), #0d90df);
      color: #fff;
    }

    .btn-secondary {
      background: #fff;
      color: var(--navy);
      border: 1px solid var(--border);
      box-shadow: none;
    }

    .btn-green {
      background: linear-gradient(135deg, var(--green), var(--green-dark));
      color: #fff;
    }

    .hero-wrap {
      padding: 28px 0 18px;
    }

    .hero {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 28px;
      overflow: hidden;
      box-shadow: var(--shadow);
    }

    .hero-media {
      position: relative;
      min-height: 430px;
      background: #dbe7f0;
    }

    .hero-media img {
      height: 100%;
      object-fit: cover;
    }

    .hero-media::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(8,20,35,0.08) 0%, rgba(8,20,35,0.00) 55%, rgba(255,255,255,0.30) 100%);
      pointer-events: none;
    }

    .hero-content {
      padding: 48px 42px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 18px;
      background:
        radial-gradient(circle at top right, rgba(240,181,68,0.18), transparent 30%),
        radial-gradient(circle at bottom left, rgba(31,116,183,0.12), transparent 36%),
        #fff;
    }

    .eyebrow {
      display: inline-flex;
      width: fit-content;
      padding: 8px 14px;
      border-radius: 999px;
      font-weight: 800;
      font-size: 0.85rem;
      color: var(--navy);
      background: rgba(31,116,183,0.10);
      border: 1px solid rgba(31,116,183,0.18);
    }

    h1 {
      margin: 0;
      font-size: clamp(2.3rem, 4vw, 4rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
    }

    .accent { color: var(--blue); }

    .hero-copy {
      margin: 0;
      font-size: 1.2rem;
      color: var(--muted);
      max-width: 560px;
    }

    .hero-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 6px;
    }

    .hero-note {
      color: var(--muted);
      font-size: 0.96rem;
    }

    .section {
      padding: 14px 0 8px;
    }

    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      margin: 10px 0 18px;
    }

    .section-title {
      margin: 0;
      font-size: clamp(1.7rem, 3vw, 2.4rem);
      letter-spacing: -0.03em;
    }

    .section-sub {
      margin: 0;
      color: var(--muted);
      font-size: 1rem;
    }

    .snapshot-grid,
    .updates-grid,
    .hub-grid {
      display: grid;
      gap: 20px;
    }

    .snapshot-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }

    .snapshot-card {
      background: linear-gradient(180deg, var(--navy), #235d8e);
      color: #fff;
      border-radius: var(--radius);
      padding: 18px;
      box-shadow: var(--shadow);
      min-height: 170px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
    }

    .snapshot-card.green { background: linear-gradient(180deg, #1f8b70, #20795f); }
    .snapshot-card.gold { background: linear-gradient(180deg, #d79a2d, #bb7f18); }
    .snapshot-card.light { background: linear-gradient(180deg, #2e83c5, #255f99); }

    .snapshot-label {
      font-size: 0.84rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      opacity: 0.92;
    }

    .snapshot-title {
      font-size: 1.75rem;
      line-height: 1.1;
      font-weight: 800;
      margin: 12px 0 8px;
    }

    .snapshot-copy {
      margin: 0;
      color: rgba(255,255,255,0.9);
      font-size: 0.96rem;
    }

    .updates-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .hub-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 22px;
      overflow: hidden;
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
    }

    .card-image {
      aspect-ratio: 16 / 10;
      overflow: hidden;
      background: #d8e6f1;
    }

    .card-image img {
      height: 100%;
      object-fit: cover;
      transition: transform 0.35s ease;
    }

    .card:hover .card-image img {
      transform: scale(1.03);
    }

    .card-body {
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      height: 100%;
    }

    .card-tag {
      color: var(--blue);
      font-weight: 800;
      font-size: 0.82rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .card-title {
      margin: 0;
      font-size: 1.55rem;
      line-height: 1.18;
      letter-spacing: -0.02em;
    }

    .card-text {
      margin: 0;
      color: var(--muted);
      font-size: 1rem;
    }

    .card-link {
      margin-top: auto;
      color: var(--blue);
      font-weight: 800;
    }

    .hub-card {
      background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(232,245,255,0.92));
      border: 1px solid var(--border);
      border-radius: 20px;
      box-shadow: var(--shadow);
      padding: 22px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .hub-card h3 {
      margin: 0;
      font-size: 1.35rem;
      letter-spacing: -0.02em;
    }

    .hub-card p {
      margin: 0;
      color: var(--muted);
    }

    .hub-links {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-top: 6px;
    }

    .hub-links a {
      color: var(--blue);
      font-weight: 700;
    }

    .feature {
      margin-top: 12px;
      background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(232,245,255,0.92));
      border: 1px solid var(--border);
      border-radius: 28px;
      box-shadow: var(--shadow);
      padding: 28px;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 28px;
      align-items: center;
    }

    .feature-copy h2 {
      margin: 0 0 10px;
      font-size: clamp(1.9rem, 3vw, 2.8rem);
      letter-spacing: -0.03em;
    }

    .feature-copy p {
      margin: 0 0 18px;
      color: var(--muted);
      font-size: 1.1rem;
    }

    .service-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 18px;
    }

    .service {
      background: rgba(31,116,183,0.06);
      border: 1px solid rgba(31,116,183,0.12);
      border-radius: 16px;
      padding: 14px;
      text-align: center;
      font-weight: 700;
      color: var(--navy);
    }

    .feature-image {
      border-radius: 22px;
      overflow: hidden;
      min-height: 360px;
      background: #dceaf4;
    }

    .feature-image img {
      height: 100%;
      object-fit: cover;
    }

    .subscribe {
      margin: 24px 0 40px;
      background: linear-gradient(135deg, #0d355a, #1564a4);
      color: #fff;
      border-radius: 24px;
      box-shadow: var(--shadow);
      padding: 28px;
      display: grid;
      grid-template-columns: 1.4fr auto;
      gap: 18px;
      align-items: center;
    }

    .subscribe h3 {
      margin: 0 0 6px;
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      letter-spacing: -0.03em;
    }

    .subscribe p {
      margin: 0;
      color: rgba(255,255,255,0.88);
      font-size: 1.04rem;
    }

    .footer {
      padding: 10px 0 34px;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .footer-inner {
      display: grid;
      grid-template-columns: 1.2fr 1fr 1fr;
      gap: 24px;
      border-top: 1px solid var(--border);
      padding-top: 18px;
    }

    .footer-title {
      color: var(--navy);
      font-weight: 800;
      margin-bottom: 10px;
    }

    .footer-links {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .footer-links a:hover {
      color: var(--blue);
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      white-space: nowrap;
      border: 0;
    }

    @media (max-width: 1080px) {
      .hero,
      .feature,
      .subscribe,
      .updates-grid,
      .snapshot-grid,
      .hub-grid {
        grid-template-columns: 1fr 1fr;
      }

      .updates-grid .card:last-child,
      .hub-grid .hub-card:last-child {
        grid-column: 1 / -1;
      }

      .service-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .footer-inner {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 760px) {
      .nav {
        flex-direction: column;
        align-items: flex-start;
        justify-content: center;
        padding: 14px 0;
      }

      .nav-links {
        width: 100%;
      }

      .hero,
      .feature,
      .subscribe,
      .updates-grid,
      .snapshot-grid,
      .hub-grid,
      .footer-inner {
        grid-template-columns: 1fr;
      }

      .hero-media {
        min-height: 280px;
      }

      .hero-content,
      .feature {
        padding: 22px;
      }

      .service-grid {
        grid-template-columns: 1fr 1fr;
      }

      .section-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .subscribe {
        padding: 22px;
      }

      .subscribe .btn,
      .btn {
        width: 100%;
      }
    }

    @media (max-width: 480px) {
      .container {
        width: min(var(--max), calc(100% - 20px));
      }

      .brand-title {
        font-size: 1.55rem;
      }

      .brand-sub {
        font-size: 0.88rem;
      }

      h1 {
        font-size: 2.2rem;
      }

      .snapshot-title {
        font-size: 1.5rem;
      }

      .card-title {
        font-size: 1.35rem;
      }

      .service-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="container nav">
      <div class="brand">
        <div class="brand-title">StayJustin</div>
        <div class="brand-sub">West Covina news • city hall • new businesses • local events</div>
      </div>

      <nav class="nav-links" aria-label="Main navigation">
        <a href="/west-covina-news/">News</a>
        <a href="/city-hall/">City Hall</a>
        <a href="/new-businesses/">New Businesses</a>
        <a href="/development/">Development</a>
        <a href="/events/">Events</a>
        <a href="/tech-help/">Tech Help</a>
        <a class="btn btn-primary" href="https://stayjustin.substack.com" target="_blank" rel="noopener noreferrer">Subscribe</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero-wrap">
      <div class="container">
        <section class="hero" aria-labelledby="home-heading">
          <div class="hero-media">
            <img src="/images/wc-downtown.jpg" alt="Downtown West Covina with the San Gabriel Mountains in the distance" />
          </div>

          <div class="hero-content">
            <span class="eyebrow">West Covina in simple terms</span>
            <h1 id="home-heading">West Covina News, City Hall Updates, and What’s Changing</h1>
            <p class="hero-copy">
              StayJustin helps busy people understand West Covina news, City Hall decisions, new businesses, development projects, road closures, events, and neighborhood changes without the usual jargon.
            </p>

            <div class="hero-actions">
              <a class="btn btn-primary" href="https://stayjustin.substack.com" target="_blank" rel="noopener noreferrer">Subscribe</a>
              <a class="btn btn-secondary" href="/west-covina-news/">Read Latest Updates</a>
            </div>

            <p class="hero-note">
              StayJustin is a local guide to West Covina news, business openings, community issues, and city decisions that affect everyday life.
            </p>
          </div>
        </section>
      </div>
    </section>

    <section class="section" id="snapshot">
      <div class="container">
        <div class="section-header">
          <div>
            <h2 class="section-title">What’s Happening in West Covina This Week</h2>
            <p class="section-sub">Quick context on meetings, business activity, local events, and city updates worth watching.</p>
          </div>
        </div>

        <div class="snapshot-grid">
          <article class="snapshot-card light">
            <div>
              <div class="snapshot-label">City Hall</div>
              <div class="snapshot-title">Planning Commission Meeting</div>
            </div>
            <p class="snapshot-copy">
              <strong>Why it matters:</strong> Development decisions often start here. This is where projects affecting housing, retail, and growth begin to take shape.
            </p>
          </article>

          <article class="snapshot-card green">
            <div>
              <div class="snapshot-label">Community</div>
              <div class="snapshot-title">Senior & Community Services</div>
            </div>
            <p class="snapshot-copy">
              <strong>Why it matters:</strong> These meetings can affect programs, recreation, and services used by residents, families, and seniors.
            </p>
          </article>

          <article class="snapshot-card gold">
            <div>
              <div class="snapshot-label">Events</div>
              <div class="snapshot-title">Neighborhood Events to Know</div>
            </div>
            <p class="snapshot-copy">
              <strong>Why it matters:</strong> Local events keep people informed, connected, and more likely to participate in the city around them.
            </p>
          </article>

          <article class="snapshot-card">
            <div>
              <div class="snapshot-label">Business</div>
              <div class="snapshot-title">New Businesses and Openings</div>
            </div>
            <p class="snapshot-copy">
              <strong>Why it matters:</strong> New businesses change where people spend time, shop, eat, and invest in West Covina.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="topic-hubs">
      <div class="container">
        <div class="section-header">
          <div>
            <h2 class="section-title">Explore West Covina by Topic</h2>
            <p class="section-sub">These topic hubs are the core of the site and should become your main SEO categories.</p>
          </div>
        </div>

        <div class="hub-grid">
          <article class="hub-card">
            <h3><a href="/city-hall/">City Hall</a></h3>
            <p>Simple breakdowns of city council meetings, agendas, votes, ordinances, and planning decisions.</p>
            <div class="hub-links">
              <a href="/city-hall/">Browse City Hall updates</a>
              <a href="/city-hall/west-covina-city-council-summary/">City council summaries</a>
              <a href="/city-hall/west-covina-planning-commission/">Planning Commission coverage</a>
            </div>
          </article>

          <article class="hub-card">
            <h3><a href="/new-businesses/">New Businesses</a></h3>
            <p>Track new restaurants, store openings, business moves, closures, and commercial activity in West Covina.</p>
            <div class="hub-links">
              <a href="/new-businesses/">Browse new businesses</a>
              <a href="/new-businesses/new-restaurants-west-covina/">New restaurants in West Covina</a>
              <a href="/new-businesses/business-openings-west-covina/">Business openings tracker</a>
            </div>
          </article>

          <article class="hub-card">
            <h3><a href="/development/">Development</a></h3>
            <p>Coverage of housing projects, downtown changes, commercial construction, and future city growth.</p>
            <div class="hub-links">
              <a href="/development/">Browse development updates</a>
              <a href="/development/downtown-west-covina-projects/">Downtown project tracker</a>
              <a href="/development/west-covina-housing-projects/">Housing and apartment projects</a>
            </div>
          </article>

          <article class="hub-card">
            <h3><a href="/traffic-road-closures/">Traffic & Road Closures</a></h3>
            <p>Useful updates on road work, detours, traffic impacts, parking changes, and transportation issues.</p>
            <div class="hub-links">
              <a href="/traffic-road-closures/">Browse traffic updates</a>
              <a href="/traffic-road-closures/west-covina-road-closures/">Current road closures</a>
              <a href="/traffic-road-closures/parking-changes-west-covina/">Parking changes</a>
            </div>
          </article>

          <article class="hub-card">
            <h3><a href="/events/">Events</a></h3>
            <p>Keep up with community events, public meetings, workshops, family activities, and local happenings.</p>
            <div class="hub-links">
              <a href="/events/">Browse local events</a>
              <a href="/events/this-week-in-west-covina/">This week in West Covina</a>
              <a href="/events/family-events-west-covina/">Family-friendly events</a>
            </div>
          </article>

          <article class="hub-card">
            <h3><a href="/west-covina-news/">West Covina News</a></h3>
            <p>The main feed for neighborhood updates, daily news, explainers, and changes that affect local life.</p>
            <div class="hub-links">
              <a href="/west-covina-news/">Browse all news</a>
              <a href="/west-covina-news/whats-happening-this-week/">What’s happening this week</a>
