---
import "../styles/global.css";

const {
  title = "StayJustin | West Covina News",
  description = "West Covina news, city hall updates, new businesses, development, traffic, and events explained simply.",
  canonical = "",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
  </head>
  <body>
    <slot />
  </body>
</html>
